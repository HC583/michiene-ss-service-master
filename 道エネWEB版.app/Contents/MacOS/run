#!/bin/zsh

APP_DIR="/Users/takahata/Documents/New project"
cd "$APP_DIR" || exit 1

URL="http://127.0.0.1:5173/web-app.html"

if ! lsof -nP -iTCP:5173 -sTCP:LISTEN >/dev/null 2>&1; then
  if command -v npm >/dev/null 2>&1; then
    npm run dev -- --host 127.0.0.1 --port 5173 > /tmp/michiene-web-app.log 2>&1 &
  elif [ -x /usr/local/bin/npm ]; then
    /usr/local/bin/npm run dev -- --host 127.0.0.1 --port 5173 > /tmp/michiene-web-app.log 2>&1 &
  fi
  sleep 2
fi

open "$URL"
